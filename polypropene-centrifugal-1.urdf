<!--
  <joint name="base_to_cap" type="fixed">
    <parent link="polypropene-base"/>
    <child link="polypropene-cap"/>
    <origin xyz="0 0 0.50" rpy="0 0 0"/>
  </joint>
  -->
  <joint name="base_to_cap" type="revolute">
    <parent link="polypropene-base"/>
    <child link="polypropene-cap"/>
    <origin xyz="0 0 0.5" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-31.4" upper="31.4" effort="10" velocity="5"/>
    <dynamics damping="0.1" friction="0.05"/>
  </joint>

</robot>