<robot name="bin_large">
  <link name="base_link">
    <collision>
      <origin xyz="0 0 0.05"/>
      <geometry><box size="2.0 2.0 0.1"/></geometry>
    </collision>

    <collision>
      <origin xyz="1.0 0 1.0"/>
      <geometry><box size="0.1 2.0 2.0"/></geometry>
    </collision>

    <collision>
      <origin xyz="-1.0 0 1.0"/>
      <geometry><box size="0.1 2.0 2.0"/></geometry>
    </collision>

    <collision>
      <origin xyz="0 1.0 1.0"/>
      <geometry><box size="2.0 0.1 2.0"/></geometry>
    </collision>

    <collision>
      <origin xyz="0 -1.0 1.0"/>
      <geometry><box size="2.0 0.1 2.0"/></geometry>
    </collision>
    
    <visual>
      <origin xyz="0 0 0"/> 
      <geometry><mesh filename="C:\Users\jbuam\OneDrive\Documents\University\MECHANICAL ENGINEERING\Final year\Final Year Project (MEng)\components\conveyor belt\bin.obj" scale="0.1 0.1 0.1"/></geometry>
    </visual>
  </link>
</robot>
